# Configuración básica
SECRET_KEY=tu_secret_key_aqui
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 días en minutos

# Base de datos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_db
POSTGRES_USER=usuario
POSTGRES_PASSWORD=contraseña
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nombre_db

# Email
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion
EMAILS_FROM_EMAIL=tu_email@gmail.com
EMAILS_FROM_NAME=GymAPI

# Superadmin
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=contraseña_segura

# Auth0 Configuration
AUTH0_DOMAIN=tu_dominio.auth0.com
AUTH0_API_AUDIENCE=https://tu-api
AUTH0_ALGORITHMS=["RS256"]
AUTH0_ISSUER=https://tu_dominio.auth0.com/
AUTH0_CLIENT_ID=tu_client_id
AUTH0_CLIENT_SECRET=tu_client_secret
AUTH0_CALLBACK_URL=http://localhost:8080/api/v1/auth/callback
AUTH0_WEBHOOK_SECRET=tu_webhook_secret
ADMIN_SECRET_KEY=tu_admin_secret_key

# Stream.io Configuration
STREAM_API_KEY=tu_stream_api_key
STREAM_API_SECRET=tu_stream_api_secret

# URLs de redirección permitidas (como JSON array)
AUTH0_ALLOWED_REDIRECT_URIS=["http://localhost:3000","http://localhost:3001","http://localhost:3005","http://localhost:3005/auth-callback"]

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=tu_redis_password
REDIS_URL=redis://:tu_redis_password@localhost:6379/0 